# Copy to .env and fill in values. Never commit .env.

# PostgreSQL — ledger (document pipeline) and client profiles (separate DBs)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ledgerdb
CLIENT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/client_database

# If true, uploads must resolve to an existing client in client_database (matched by name)
REQUIRE_CLIENT_ID_ON_UPLOAD=false

# Optional: where extracted JSON snapshots are written (default: backend/local_extractions/)
# EXTRACTED_JSON_DIR=

# API keys (set as needed for your deployment)
# NUMIND_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
